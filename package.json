{
  "name": "miko-code",
  "version": "0.1.2",
  "type": "module",
  "bin": {
    "miko": "bin/miko"
  },
  "author": "Sarp Pehlivan",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Sarp2/miko.git"
  },
  "bugs": {
    "url": "https://github.com/Sarp2/miko/issues"
  },
  "keywords": [
    "ai",
    "coding-agent",
    "claude-code",
    "codex",
    "developer-tools",
    "git-worktree"
  ],
  "scripts": {
    "build": "vite build",
    "check": "tsc --noEmit && vite build",
    "dev": "bun run ./scripts/dev.ts",
    "dev:client": "vite dev",
    "dev:server": "bun run ./src/server/server.ts",
    "lint": "bunx biome check",
    "lint:fix": "bunx biome check --write",
    "format": "bunx biome format --write",
    "test": "bun test",
    "prepack": "bun run build",
    "pack:dry": "npm pack --dry-run"
  },
  "packageManager": "bun@1.3.5",
  "engines": {
    "bun": ">=1.3.5"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.177",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@phosphor-icons/react": "^2.1.10",
    "@pierre/diffs": "^1.1.12",
    "@pierre/vscode-icons": "^0.0.9",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-serialize": "^0.14.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/headless": "^6.0.0",
    "@xterm/xterm": "^6.0.0",
    "cloudflared": "^0.7.1",
    "default-shell": "^2.2.0",
    "file-type": "^22.0.0",
    "qrcode": "^1.5.4",
    "radix-ui": "^1.4.3",
    "shadcn": "^4.2.0",
    "sonner": "^2.0.7",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/vite": "^4.3.0",
    "@types/bun": "latest",
    "@types/node": "^24.10.1",
    "@types/qrcode": "^1.5.6",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.8.0",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.12.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.1.18",
    "typescript": "5.8.3",
    "vite": "^6.0.0",
    "zustand": "^5.0.10"
  },
  "description": "A fast Conductor-like web UI for running Claude Code, Codex, and AI coding agents across workspaces.",
  "files": [
    "bin/miko",
    "dist/client",
    "src/server/**/*.ts",
    "src/shared/**/*.ts",
    "!src/**/*.test.ts",
    "!src/**/*.test.tsx",
    "LICENSE",
    "README.md",
    "tsconfig.json"
  ]
}
